# PostgreSQL
PGPORT=5432
PGUSER=admin
PGDATABASE=project_name
# Note: PGDATA, PGHOST, and REDIS_DATA_DIR are set automatically by the flox hook

# Redis
REDIS_PORT=6379

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# App
INTERNAL_JWT_SECRET=
CORS_ORIGIN=http://localhost:3000
PORT=3001
NODE_ENV=development

# Frontend (Next.js public — must be the real backend origin, used for postMessage origin check in OAuth popup)
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:3001

# Computed (constructed from the above)
DATABASE_URL=postgresql://admin@localhost:5432/project_name
REDIS_URL=redis://localhost:6379
